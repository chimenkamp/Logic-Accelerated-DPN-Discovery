      <transition id="t_ER Registration_1">
        <name>
          <text>ER Registration</text>
        </name>
        <toolspecific tool="dpn-discovery" version="1.0">
          <guard>true</guard>
        </toolspecific>
        <toolspecific tool="dpn-discovery" version="1.0">
          <update variable="DiagnosticSputum">0</update>
          <update variable="Hypoxie">0</update>
          <update variable="SIRSCritLeucos">0</update>
        </toolspecific>
      </transition>
      <arc id="arc_p_q80_to_t_ER Registration_1" source="p_q80" target="t_ER Registration_1" />
      <arc id="arc_t_ER Registration_1_to_p_q80" source="t_ER Registration_1" target="p_q80" />
      <transition id="t_ER Triage_2">
        <name>
          <text>ER Triage</text>
        </name>
        <toolspecific tool="dpn-discovery" version="1.0">
          <guard>true</guard>
        </toolspecific>
      </transition>
      <arc id="arc_p_q80_to_t_ER Triage_2" source="p_q80" target="t_ER Triage_2" />
      <arc id="arc_t_ER Triage_2_to_p_q80" source="t_ER Triage_2" target="p_q80" />
      <transition id="t_ER Sepsis Triage_3">
        <name>
          <text>ER Sepsis Triage</text>
        </name>
        <toolspecific tool="dpn-discovery" version="1.0">
          <guard>true</guard>
        </toolspecific>
      </transition>
      <arc id="arc_p_q80_to_t_ER Sepsis Triage_3" source="p_q80" target="t_ER Sepsis Triage_3" />
      <arc id="arc_t_ER Sepsis Triage_3_to_p_q80" source="t_ER Sepsis Triage_3" target="p_q80" />
      <transition id="t_CRP_4">
        <name>
          <text>CRP</text>
        </name>
        <toolspecific tool="dpn-discovery" version="1.0">
          <guard>(and (&lt; (+ 20 (* -1 Age)) 0) (&gt;= (+ 40 (* -1 Age)) 0))</guard>
        </toolspecific>
        <toolspecific tool="dpn-discovery" version="1.0">
          <update variable="CRP">CRP</update>
        </toolspecific>
      </transition>
      <arc id="arc_p_q80_to_t_CRP_4" source="p_q80" target="t_CRP_4" />
      <arc id="arc_t_CRP_4_to_p_q4" source="t_CRP_4" target="p_q4" />
      <transition id="t_Leucocytes_5">
        <name>
          <text>Leucocytes</text>
        </name>
        <toolspecific tool="dpn-discovery" version="1.0">
          <guard>true</guard>
        </toolspecific>
        <toolspecific tool="dpn-discovery" version="1.0">
          <update variable="Leucocytes">Diagnose</update>
        </toolspecific>
      </transition>
      <arc id="arc_p_q4_to_t_Leucocytes_5" source="p_q4" target="t_Leucocytes_5" />
      <arc id="arc_t_Leucocytes_5_to_p_q5" source="t_Leucocytes_5" target="p_q5" />
      <transition id="t_LacticAcid_6">
        <name>
          <text>LacticAcid</text>
        </name>
        <toolspecific tool="dpn-discovery" version="1.0">
          <guard>true</guard>
        </toolspecific>
        <toolspecific tool="dpn-discovery" version="1.0">
          <update variable="LacticAcid">Diagnose</update>
        </toolspecific>
      </transition>
      <arc id="arc_p_q5_to_t_LacticAcid_6" source="p_q5" target="t_LacticAcid_6" />
      <arc id="arc_t_LacticAcid_6_to_p_q293" source="t_LacticAcid_6" target="p_q293" />
      <transition id="t_IV Liquid_7">
        <name>
          <text>IV Liquid</text>
        </name>
        <toolspecific tool="dpn-discovery" version="1.0">
          <guard>true</guard>
        </toolspecific>
      </transition>
      <arc id="arc_p_q293_to_t_IV Liquid_7" source="p_q293" target="t_IV Liquid_7" />
      <arc id="arc_t_IV Liquid_7_to_p_q294" source="t_IV Liquid_7" target="p_q294" />
      <transition id="t_IV Antibiotics_8">
        <name>
          <text>IV Antibiotics</text>
        </name>
        <toolspecific tool="dpn-discovery" version="1.0">
          <guard>true</guard>
        </toolspecific>
      </transition>
      <arc id="arc_p_q294_to_t_IV Antibiotics_8" source="p_q294" target="t_IV Antibiotics_8" />
      <arc id="arc_t_IV Antibiotics_8_to_p_q102" source="t_IV Antibiotics_8" target="p_q102" />
      <transition id="t_IV Liquid_9">
        <name>
          <text>IV Liquid</text>
        </name>
        <toolspecific tool="dpn-discovery" version="1.0">
          <guard>true</guard>
        </toolspecific>
        <toolspecific tool="dpn-discovery" version="1.0">
          <update variable="Age">Age</update>
        </toolspecific>
      </transition>
      <arc id="arc_p_q80_to_t_IV Liquid_9" source="p_q80" target="t_IV Liquid_9" />
      <arc id="arc_t_IV Liquid_9_to_p_q9" source="t_IV Liquid_9" target="p_q9" />
      <transition id="t_ER Registration_10">
        <name>
          <text>ER Registration</text>
        </name>
        <toolspecific tool="dpn-discovery" version="1.0">
          <guard>true</guard>
        </toolspecific>
        <toolspecific tool="dpn-discovery" version="1.0">
          <update variable="DiagnosticArtAstrup">0</update>
          <update variable="DiagnosticBlood">1</update>
          <update variable="DiagnosticECG">1</update>
          <update variable="DiagnosticIC">1</update>
          <update variable="DiagnosticLacticAcid">1</update>
          <update variable="DiagnosticLiquor">0</update>
          <update variable="DiagnosticOther">0</update>
          <update variable="DiagnosticSputum">0</update>
          <update variable="DiagnosticUrinaryCulture">1</update>
          <update variable="DiagnosticUrinarySediment">1</update>
          <update variable="DiagnosticXthorax">1</update>
          <update variable="DisfuncOrg">0</update>
          <update variable="Hypotensie">0</update>
          <update variable="Hypoxie">0</update>
          <update variable="InfectionSuspected">1</update>
          <update variable="Infusion">1</update>
          <update variable="Oligurie">0</update>
          <update variable="SIRSCritHeartRate">1</update>
          <update variable="SIRSCritLeucos">0</update>
          <update variable="SIRSCritTachypnea">0</update>
          <update variable="SIRSCritTemperature">1</update>
          <update variable="SIRSCriteria2OrMore">1</update>
        </toolspecific>
      </transition>
      <arc id="arc_p_q9_to_t_ER Registration_10" source="p_q9" target="t_ER Registration_10" />
      <arc id="arc_t_ER Registration_10_to_p_q10" source="t_ER Registration_10" target="p_q10" />
      <transition id="t_ER Triage_11">
        <name>
          <text>ER Triage</text>
        </name>
        <toolspecific tool="dpn-discovery" version="1.0">
          <guard>true</guard>
        </toolspecific>
      </transition>
      <arc id="arc_p_q10_to_t_ER Triage_11" source="p_q10" target="t_ER Triage_11" />
      <arc id="arc_t_ER Triage_11_to_p_q11" source="t_ER Triage_11" target="p_q11" />
      <transition id="t_ER Sepsis Triage_12">
        <name>
          <text>ER Sepsis Triage</text>
        </name>
        <toolspecific tool="dpn-discovery" version="1.0">
          <guard>true</guard>
